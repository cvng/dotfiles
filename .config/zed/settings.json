{
  "show_wrap_guides": true,
  "base_keymap": "JetBrains",
  "tabs": {
    "file_icons": true,
  },
  "buffer_font_weight": 600,
  "agent": {
    "show_turn_stats": true,
    "favorite_models": [
      {
        "provider": "amazon-bedrock",
        "model": "claude-opus-4-6-thinking",
        "enable_thinking": true,
      },
    ],
    "tool_permissions": {
      "tools": {
        "terminal": {
          "default": "allow",
        },
      },
      "default": "confirm",
    },
    "default_profile": "write",
    "default_model": {
      "provider": "amazon-bedrock",
      "model": "claude-opus-4-6-thinking",
    },
    "default_view": "text_thread",
    "play_sound_when_agent_done": true,
  },
  "agent_buffer_font_size": 16.0,
  "autosave": "on_focus_change",
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 18,
  "completions": {
    "words": "disabled",
  },
  "cursor_blink": true,
  "debugger": { "dock": "bottom" },
  "diagnostics": { "inline": { "enabled": true } },
  "diff_view_style": "unified",
  "edit_predictions": { "mode": "subtle" },
  "git": {
    "inline_blame": {
      "delay_ms": 5000,
      "show_commit_summary": true,
      "enabled": false,
    },
  },
  "git_panel": { "tree_view": false, "dock": "right" },
  "gutter": { "line_numbers": true },
  "hide_mouse": "on_typing_and_movement",
  "icon_theme": "Colored Zed Icons Theme Dark",
  "indent_guides": {
    "active_line_width": 2,
    "line_width": 2,
    "background_coloring": "disabled",
    "coloring": "fixed",
    "enabled": false,
  },
  "inline_code_actions": false,
  "language_models": {
    "bedrock": {
      "authentication_method": "named_profile",
      "region": "us-east-1",
      "profile": "default",
    },
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": { "check": { "command": "clippy" } },
    },
  },
  "minimap": { "show": "auto" },
  "outline_panel": { "dock": "right", "indent_guides": { "show": "never" } },
  "project_panel": { "dock": "right", "indent_guides": { "show": "never" } },
  "relative_line_numbers": "enabled",
  "scroll_beyond_last_line": "off",
  "scrollbar": { "show": "never" },
  "search": {
    "case_sensitive": true,
    "whole_word": true,
  },
  "show_completion_documentation": false,
  "show_edit_predictions": false,
  "show_whitespaces": "trailing",
  "snippet_sort_order": "none",
  "tab_bar": { "show": true },
  "tab_size": 2,
  "terminal": {
    "font_family": "JetBrains Mono",
    "font_features": {},
    "font_weight": 600,
    "toolbar": { "breadcrumbs": true },
  },
  "theme": {
    "mode": "system",
    "light": "Gruvbox Light Hard",
    "dark": "Oscura",
  },
  "title_bar": { "show_user_picture": true },
  "ui_font_family": "JetBrains Mono",
  "ui_font_size": 19,
  "ui_font_weight": 600,
  "use_smartcase_search": true,
  "vertical_scroll_margin": 100,
  "vim_mode": true,
  "which_key": { "enabled": true },
  "wrap_guides": [100],
}
