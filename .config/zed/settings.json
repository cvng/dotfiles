{
  "autosave": "on_focus_change",
  "base_keymap": "VSCode",
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 19,
  "buffer_font_weight": 600,
  "centered_layout": {
    "left_padding": 0.1,
    "right_padding": 0.1,
  },
  "completions": {
    "words": "disabled",
  },
  "confirm_quit": true,
  "debugger": {
    "dock": "bottom",
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "diff_view_style": "unified",
  "disable_ai": true,
  "file_scan_exclusions": [],
  "file_types": {
    "GitHub Actions": [".github/workflows/*.yml"],
  },
  "git": {
    "inline_blame": {
      "delay_ms": 5000,
      "enabled": false,
      "show_commit_summary": true,
    },
  },
  "git_panel": {
    "dock": "right",
    "tree_view": false,
  },
  "gutter": {
    "folds": false,
  },
  "icon_theme": {
    "dark": "Colored Zed Icons Theme Dark",
    "light": "Colored Zed Icons Theme Light",
    "mode": "system",
  },
  "indent_guides": {
    "enabled": false,
  },
  "inlay_hints": {
    "enabled": false,
  },
  "inline_code_actions": false,
  "lsp": {
    "gh-actions-language-server": {},
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
      },
    },
    "vtsls": {
      "settings": {
        "vtsls": {
          "experimental": {
            "completion": {
              "enableServerSideFuzzyMatch": true,
              "entriesLimit": 2,
            },
          },
        },
      },
    },
  },
  "lsp_document_colors": "background",
  "outline_panel": {
    "dock": "right",
    "indent_guides": {
      "show": "never",
    },
  },
  "project_panel": {
    "dock": "right",
    "indent_guides": {
      "show": "never",
    },
  },
  "redact_private_values": true,
  "relative_line_numbers": "enabled",
  "scroll_beyond_last_line": "off",
  "scrollbar": {
    "show": "never",
  },
  "search": {
    "case_sensitive": true,
    "whole_word": true,
  },
  "show_completion_documentation": false,
  "show_edit_predictions": false,
  "show_whitespaces": "trailing",
  "snippet_sort_order": "none",
  "tab_bar": {
    "show": false,
  },
  "tab_size": 2,
  "tabs": {
    "file_icons": true,
    "show_diagnostics": "all",
  },
  "terminal": {
    "blinking": "on",
    "font_family": "JetBrains Mono",
    "font_weight": 600,
    "line_height": "comfortable",
    "option_as_meta": true,
    "toolbar": {
      "breadcrumbs": true,
    },
  },
  "theme": {
    "dark": "Oscura",
    "light": "Gruvbox Light Hard",
    "mode": "system",
  },
  "title_bar": {
    "show_user_picture": false,
  },
  "toolbar": {
    "quick_actions": false,
  },
  "ui_font_family": "JetBrains Mono",
  "ui_font_size": 21,
  "ui_font_weight": 600,
  "use_smartcase_search": true,
  "vertical_scroll_margin": 10,
  "vim_mode": true,
  "when_closing_with_no_tabs": "keep_window_open",
  "which_key": {
    "enabled": true,
  },
  "wrap_guides": [],
}
